    public static List<SVMXC__PM_History__c> createPMHistories(Integer numPMHistories, Boolean withVisitType)
    {
        BusinessHours DEFAULT_BH = [SELECT Id, TimeZoneSidKey, IsActive FROM BusinessHours WHERE IsDefault = true];
 
        List<SVMXC__PM_History__c> pmHistories = new List<SVMXC__PM_History__c>();
        if(numPMHistories != null && numPMHistories > 0) {
 
            // Create Contact
            List<Contact> contacts = createContacts(1);
 
            // Create Account
            Account acct = new Account(
                    Name = 'Test Account',
                    BillingStreet = '123 Test Lane',
                    BillingCity = 'Houston',
                    BillingState = 'TX',
                    BillingPostalCode = '77070',
                    BillingCountry = 'United States',
                    SVMXC__Access_Hours__c = DEFAULT_BH.Id,
                    SVMX_PS_Contact__c = contacts[0].Id
            );
            System.debug('Inserting Account: ' + acct);
            insert acct;
 
            // Create Service Levels
            List<SVMXC__Service_Level__c> serviceLevels = new List<SVMXC__Service_Level__c>{
                new SVMXC__Service_Level__c(Name = 'Test Annual', SVMXC__Active__c = true, BD_Site_Account__c = acct.Id,
                    SVMX_PS_Visit_Type__c = 'Annual', SVMXC__Business_Hours__c = DEFAULT_BH.Id, BD_Order_Type__c = 'Preventive Maintenance'),
                new SVMXC__Service_Level__c(Name = 'Test Semi-Annual', SVMXC__Active__c = true, BD_Site_Account__c = acct.Id,
                    SVMX_PS_Visit_Type__c = 'Semi-Annual', SVMXC__Business_Hours__c = DEFAULT_BH.Id, BD_Order_Type__c = 'Preventive Maintenance'),
                new SVMXC__Service_Level__c(Name = 'Test Quarterly', SVMXC__Active__c = true, BD_Site_Account__c = acct.Id,
                    SVMX_PS_Visit_Type__c = 'Quarterly', SVMXC__Business_Hours__c = DEFAULT_BH.Id, BD_Order_Type__c = 'Preventive Maintenance'),
                new SVMXC__Service_Level__c(Name = 'Test Monthly', SVMXC__Active__c = true, BD_Site_Account__c = acct.Id,
                    SVMX_PS_Visit_Type__c = 'Monthly', SVMXC__Business_Hours__c = DEFAULT_BH.Id, BD_Order_Type__c = 'Preventive Maintenance'),
                new SVMXC__Service_Level__c(Name = 'Test Weekly', SVMXC__Active__c = true, BD_Site_Account__c = acct.Id,
                    SVMX_PS_Visit_Type__c = 'Weekly', SVMXC__Business_Hours__c = DEFAULT_BH.Id, BD_Order_Type__c = 'Preventive Maintenance')
            };
            System.debug('Inserting Service Level list: ' + serviceLevels);
            insert serviceLevels;
 
            // Create Work Orders
            List<SVMXC__Service_Order__c> wos = new List<SVMXC__Service_Order__c>();
            for(Integer i=0; i<numPMHistories; i++)
            {
                SVMXC__Service_Order__c wo = new SVMXC__Service_Order__c(
                        SVMXC__Company__c = acct.Id,
                        SVMXC__Order_Type__c = 'Preventive Maintenance',
                        SVMXC__Is_SLA_Calculated__c = false,
                        SVMX_PS_Visit_Type__c = '',
                        SVMXC__SLA_Terms__c = null,
                        SVMX_PS_Assign_to_WorkGroup__c = false,
                        SVMXC__Order_Status__c = 'New'
                );
 
                wos.add(wo);
            }
 
            System.debug('Inserting Work Order list: ' + wos);
            insert wos;
 
 
            // Create a PM Plan to be used by the PM Schedule Definition
            SVMXC__PM_Plan__c pmPlan = new SVMXC__PM_Plan__c(
                    Name = 'Test PM Plan', SVMXC__Account__c = acct.Id
            );
            System.debug('Inserting PM Plan: ' + pmPlan);
            insert pmPlan;
 
            // AM 2026-07-15: Added Task Template (SVMXC__Task_Template__c) creation.
            // Root cause: the "PM Schedule Definition - Update Visit Type" flow runs unconditionally
            // (no entry/filter conditions) on every insert/update of SVMXC__PM_Schedule_Definition__c
            // and overwrites SVMX_PS_Visit_Type__c with the value from
            // {!$Record.SVMXC__Work_Order_Purpose__r.SVMX_Frontec_Type_of_Visit__c}.
            // Setting SVMX_PS_Visit_Type__c directly on the PM Schedule Definition record (old approach)
            // was therefore always overwritten to null immediately after insert, since
            // SVMXC__Work_Order_Purpose__c was never populated. Visit Type must instead be driven
            // through a related Task Template record.
            SVMXC__Task_Template__c taskTemplate = new SVMXC__Task_Template__c(
                    SVMX_Frontec_Type_of_Visit__c = withVisitType ? 'Monthly' : ''
            );
            System.debug('AM: Inserting Task Template: ' + taskTemplate);
            insert taskTemplate;
 
            // Create PM Schedule Definitions
            // AM 2026-07-15: Removed direct SVMX_PS_Visit_Type__c assignment (was being silently
            // overwritten to null by the flow described above). Now linking to the Task Template via
            // SVMXC__Work_Order_Purpose__c so the flow resolves Visit Type correctly on insert.
            List<SVMXC__PM_Schedule_Definition__c> pmSchedDefs = new List<SVMXC__PM_Schedule_Definition__c>();
            for(Integer i=0; i<numPMHistories; i++)
            {
                SVMXC__PM_Schedule_Definition__c pmSchedDef = new SVMXC__PM_Schedule_Definition__c(
                        SVMXC__Work_Order_Purpose__c = taskTemplate.Id, // AM: drives Visit Type via flow
                        SVMXC__PM_Plan__c = pmPlan.Id
                );
                pmSchedDefs.add(pmSchedDef);
            }
 
            System.debug('Inserting PM Schedule Definition list: ' + pmSchedDefs);
            insert pmSchedDefs;
 
 
            // Create PM Histories
            for(Integer i=0; i<numPMHistories; i++)
            {
                SVMXC__PM_History__c pmHistory = new SVMXC__PM_History__c(
                        SVMXC__Work_Order__c = wos[i].Id,
                        SVMXC__PM_Schedule_Definition__c = pmSchedDefs[i].Id,
                        SVMXC__PM_Plan__c = pmPlan.Id
                );
 
                pmHistories.add(pmHistory);
            }
 
            System.debug('Inserting PM History list: ' + pmHistories);
            insert pmHistories;
        }
 
        System.debug('Returning PM Histories: ' + pmHistories);
        return pmHistories;
    }
 
    public static List<Contact> createContacts(Integer numContacts)
    {
        // Create Contacts
        List<Contact> contacts = new List<Contact>();
        for(Integer i=0; i<numContacts; i++)
        {
            Contact contact = new Contact(
                    FirstName = 'Test',
                    LastName = 'Contact' + i,
                    Email = 'TestEmail' + i + '@test.com'
            );
 
            contacts.add(contact);
        }
 
        insert contacts;
        System.debug('contacts list: '+ contacts);
        return contacts;
    }
 
